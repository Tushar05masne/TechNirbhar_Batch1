<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

<!-- This log file will have only automation logs. After any update in this file, we have to update the project so that latest xml file will be reffered.
			right click on project-> Maven-> Update project. -->

	<Properties>
		<Property name="basepath">./logs</Property>	<!-- ./-> current project, logs-foldername.
														 It will generate logfiles in 'logs' folder. -->
	</Properties>

  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
    
	<RollingFile name="File" fileName="${basepath}/automation.log"
                       filePattern="${basepath}/automation-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <SizeBasedTriggeringPolicy size="5000" />
          </RollingFile>
    
    
  </Appenders>
  
  <Loggers>
	    <Root level="Debug">		<!-- Here we can use multiple log level -> All < Trace < Debug < Info < Warn < Error < Fatal < Off -->
	     <!--<AppenderRef ref="Console"/> -->	<!-- generate logs on Console-->
	      <AppenderRef ref="File"/>		<!-- generate logs in File-->
	    </Root>
  </Loggers>
</Configuration>